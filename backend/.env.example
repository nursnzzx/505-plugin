# ─────────── Server ───────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_URL=http://localhost:3000

# ─────────── Database ───────────
DATABASE_URL="postgresql://kanttools:kanttools@localhost:5432/kanttools?schema=public"

# ─────────── JWT ───────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long_xxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long_xx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─────────── License signing ───────────
LICENSE_SIGNING_SECRET=change_me_license_signing_secret_xxxxxxxxxxx

# ─────────── Telegram ───────────
TELEGRAM_BOT_TOKEN=123456:CHANGE_ME
TELEGRAM_BOT_USERNAME=KantToolsBot
TELEGRAM_WEBAPP_URL=https://app.kanttools.example
TELEGRAM_ADMIN_IDS=

# ─────────── CORS ───────────
CORS_ORIGINS=http://localhost:3000,https://app.kanttools.example

# ─────────── Rate limiting ───────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ─────────── Device policy ───────────
DEVICE_CHANGE_LIMIT=3
TRIAL_DURATION_DAYS=7

# ─────────── Admin bootstrap ───────────
ADMIN_EMAIL=admin@kanttools.local
ADMIN_PASSWORD=ChangeMe123!
