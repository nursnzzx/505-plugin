{
  "name": "kanttools",
  "version": "1.0.0",
  "private": true,
  "description": "Nurse 505 Plugin — licensing ecosystem for desktop plugins with Telegram integration",
  "workspaces": [
    "backend",
    "web",
    "bot"
  ],
  "scripts": {
    "dev": "concurrently -n api,web,bot -c blue,green,magenta \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:bot\"",
    "dev:api": "npm --workspace backend run dev",
    "dev:web": "npm --workspace web run dev",
    "dev:bot": "npm --workspace bot run dev",
    "build": "npm --workspace backend run build && npm --workspace web run build && npm --workspace bot run build",
    "db:generate": "npm --workspace backend run prisma:generate",
    "db:migrate": "npm --workspace backend run prisma:migrate",
    "db:seed": "npm --workspace backend run prisma:seed",
    "lint": "npm --workspace backend run lint && npm --workspace web run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20"
  }
}
